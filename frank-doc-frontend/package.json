{
  "name": "frank-doc-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:embedded": "ng serve --serve-path /context/iaf/frankdoc/",
    "build": "ng build",
    "lint": "eslint ./src",
    "prettier": "prettier -w .",
    "test": "ng test",
    "test:ci": "ng test --no-watch --no-progress --browsers=ChromeHeadless",
    "watch": "ng build --watch --configuration development",
    "prepare": "cd .. && husky install frank-doc-frontend/.husky"
  },
