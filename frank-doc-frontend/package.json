    "@angular/platform-browser-dynamic": "^21.2.10",
    "@angular/router": "^21.2.10",
    "@frankframework/angular-components": "^1.4.3",
    "@frankframework/doc-library-core": "^1.0.3",
    "@frankframework/doc-library-ng": "^1.0.3",
    "fuse.js": "^7.3.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.3.1",
